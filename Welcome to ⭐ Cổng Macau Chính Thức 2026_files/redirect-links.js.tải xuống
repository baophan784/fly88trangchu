/* Apply window.REDIRECT_URL (from config.js) to all .redirect-link anchors.
   Main CTA triggers a Bầu Cua mini-game modal:
     1. User picks 1 of 6 symbols (🦌 Nai, 🦀 Cua, 🐟 Cá, 🐓 Gà, 🎃 Bầu, 🦐 Tôm)
     2. 3 dice shake and reveal random results
     3. Always wins (≥1 match guaranteed) → "Chúc mừng" → redirect CTA
*/
(function () {
  'use strict';

  /* All 6 Bầu Cua symbols */
  var SYMBOLS = ['🦌', '🦀', '🐟', '🐓', '🎃', '🦐'];

  /* Roll duration constants */
  var ROLL_INTERVAL_MS = 110;
  var ROLL_TOTAL_MS    = 2800;

  document.addEventListener('DOMContentLoaded', function () {
    var url = window.REDIRECT_URL || '#';

    /* --- Apply redirect URL to all flag/inline links --- */
    var links = document.querySelectorAll('a.redirect-link');
    for (var i = 0; i < links.length; i++) {
      links[i].href = url;
    }

    /* --- DOM refs --- */
    var mainCta     = document.getElementById('main-cta');
    var modal       = document.getElementById('casino-modal');
    var modalTitle  = document.getElementById('modal-title');
    var modalMsg    = document.getElementById('modal-message');
    var finalCta    = document.getElementById('final-cta');
    var picker      = document.getElementById('baucua-picker');
    var diceContainer = document.getElementById('dice-container');
    var dice        = [
      document.getElementById('dice-1'),
      document.getElementById('dice-2'),
      document.getElementById('dice-3')
    ];

    /* Guard: exit silently if required elements are missing */
    if (!mainCta || !modal || !picker || !diceContainer) return;

    /* --- State --- */
    var pickedSymbol  = null;
    var rollTimer     = null;

    /* -------------------------------------------------------
       resetModal — restore picker view for a fresh game
    ------------------------------------------------------- */
    function resetModal() {
      pickedSymbol = null;
      if (rollTimer) { clearInterval(rollTimer); rollTimer = null; }

      modalTitle.textContent = 'BẦU CUA MAY MẮN';
      modalMsg.textContent   = 'Hãy chọn ký hiệu may mắn...';
      modalMsg.classList.remove('success-text');
      finalCta.classList.add('hidden');

      /* Show picker, hide dice */
      picker.classList.remove('hidden');
      diceContainer.classList.add('hidden');

      /* Clear selected state on all symbol buttons */
      var btns = picker.querySelectorAll('.baucua-symbol');
      for (var i = 0; i < btns.length; i++) {
        btns[i].classList.remove('selected');
        btns[i].disabled = false;
      }

      /* Stop dice shake */
      setDiceShaking(false);
    }

    /* -------------------------------------------------------
       setDiceShaking — add/remove CSS shake class on all dice
    ------------------------------------------------------- */
    function setDiceShaking(active) {
      for (var i = 0; i < dice.length; i++) {
        if (!dice[i]) continue;
        if (active) {
          dice[i].classList.add('shaking');
        } else {
          dice[i].classList.remove('shaking');
        }
      }
    }

    /* -------------------------------------------------------
       rollSymbol — return a random symbol from the array
    ------------------------------------------------------- */
    function rollSymbol() {
      return SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)];
    }

    /* -------------------------------------------------------
       startRoll — animate dice, then reveal guaranteed win
       Strategy: force at least one die to match pickedSymbol
       so the player always wins (matches game UX requirement).
    ------------------------------------------------------- */
    function startRoll(picked) {
      /* Transition UI to dice view */
      picker.classList.add('hidden');
      diceContainer.classList.remove('hidden');
      modalMsg.textContent = 'Xúc xắc đang lăn...';
      modalMsg.classList.remove('success-text');
      setDiceShaking(true);

      /* Randomise dice faces during roll */
      var elapsed   = 0;
      rollTimer = setInterval(function () {
        for (var i = 0; i < dice.length; i++) {
          if (dice[i]) dice[i].textContent = rollSymbol();
        }
        elapsed += ROLL_INTERVAL_MS;

        if (elapsed >= ROLL_TOTAL_MS) {
          clearInterval(rollTimer);
          rollTimer = null;
          revealResult(picked);
        }
      }, ROLL_INTERVAL_MS);
    }

    /* -------------------------------------------------------
       revealResult — finalise dice, always produce ≥1 match
    ------------------------------------------------------- */
    function revealResult(picked) {
      setDiceShaking(false);

      /* Generate three final symbols */
      var results = [rollSymbol(), rollSymbol(), rollSymbol()];

      /* Guarantee at least one die shows the picked symbol */
      var matchIndex = Math.floor(Math.random() * 3);
      results[matchIndex] = picked;

      /* Display final symbols */
      for (var i = 0; i < dice.length; i++) {
        if (dice[i]) dice[i].textContent = results[i];
      }

      /* Count matches for flavour text */
      var matchCount = 0;
      for (var j = 0; j < results.length; j++) {
        if (results[j] === picked) matchCount++;
      }

      var multiplierText = matchCount === 3 ? 'x3 — Đại thắng!' :
                           matchCount === 2 ? 'x2 — Thắng lớn!'  :
                                             'x1 — Trúng rồi!';

      modalTitle.textContent  = 'CHÚC MỪNG 🎉';
      modalMsg.textContent    = 'Bạn thắng ' + multiplierText + ' Nhận thưởng ngay!';
      modalMsg.classList.add('success-text');

      finalCta.textContent = 'VÀO CHƠI NGAY — NHẬN THƯỞNG';
      finalCta.classList.remove('hidden');
    }

    /* -------------------------------------------------------
       Symbol picker click — delegate on parent grid
    ------------------------------------------------------- */
    var grid = document.getElementById('baucua-grid');
    if (grid) {
      grid.addEventListener('click', function (e) {
        var btn = e.target.closest('.baucua-symbol');
        if (!btn || btn.disabled) return;

        pickedSymbol = btn.getAttribute('data-symbol');
        if (!pickedSymbol) return;

        /* Mark selection */
        var allBtns = grid.querySelectorAll('.baucua-symbol');
        for (var i = 0; i < allBtns.length; i++) {
          allBtns[i].classList.remove('selected');
          allBtns[i].disabled = true; /* prevent double-pick */
        }
        btn.classList.add('selected');

        /* Brief delay so user sees selection highlight before dice appear */
        setTimeout(function () {
          startRoll(pickedSymbol);
        }, 280);
      });
    }

    /* -------------------------------------------------------
       Final CTA click — navigate to redirect URL
    ------------------------------------------------------- */
    finalCta.addEventListener('click', function () {
      window.location.href = url;
    });

    /* -------------------------------------------------------
       Main CTA click — open modal, reset state
    ------------------------------------------------------- */
    mainCta.addEventListener('click', function (e) {
      e.preventDefault();
      resetModal();
      modal.style.display = 'flex';
    });

    /* -------------------------------------------------------
       Close modal on overlay background click
       (click on the dark backdrop, not the content box)
    ------------------------------------------------------- */
    modal.addEventListener('click', function (e) {
      if (e.target === modal) {
        modal.style.display = 'none';
        if (rollTimer) { clearInterval(rollTimer); rollTimer = null; }
      }
    });
  });
})();
